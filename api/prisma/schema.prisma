generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {

  id     Int     @id @default(autoincrement())
  name   String  @unique

  matchesA Match[] @relation("PlayerA")
  matchesB Match[] @relation("PlayerB")
  dayStats PlayerDayStat[]
}

model Match {

  id      Int @id @default(autoincrement())

  gameId  String @unique
  time    BigInt

  playerAId Int
  playerBId Int

  playerAMove String
  playerBMove String
  playerAMoveValid Boolean @default(true)
  playerBMoveValid Boolean @default(true)
  isValid Boolean @default(true)
  invalidReason String?

  result   String
  winnerId Int?

  playerA Player @relation("PlayerA", fields: [playerAId], references: [id])
  playerB Player @relation("PlayerB", fields: [playerBId], references: [id])

  createdAt DateTime @default(now())

  @@index([time])
  @@index([playerAId])
  @@index([playerBId])
  @@index([winnerId])
}

model SyncState {

  id String @id

  nextCursor String?
  isRunning Boolean @default(false)
  triggerSource String?

  pagesProcessed Int @default(0)
  matchesFetched Int @default(0)
  matchesCreated Int @default(0)
  matchesUpdated Int @default(0)
  invalidMatches Int @default(0)

  lastError String?
  lastStartedAt DateTime?
  lastCompletedAt DateTime?
  lastHeartbeatAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SyncedHistoryCursor {

  cursor String @id

  createdAt DateTime @default(now())
}

model PlayerDayStat {

  playerId Int
  day DateTime @db.Date

  matches Int @default(0)
  wins Int @default(0)
  losses Int @default(0)
  draws Int @default(0)
  invalidMatches Int @default(0)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([playerId, day])
  @@index([day])
  @@index([wins])
}
